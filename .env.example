# ── AI Resume Optimizer — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the real .env to version control.

# ── Backend ───────────────────────────────────────────────────────────────────

# OpenAI API key (required)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Environment: "development" | "production"
ENVIRONMENT=development

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# These must be prefixed with NEXT_PUBLIC_ to be accessible in the browser.

# Backend API URL (required for the frontend to talk to FastAPI)
# Development: http://localhost:8000
# Production: https://your-api-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
